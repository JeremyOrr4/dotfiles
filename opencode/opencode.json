{
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": true,
  "share": "manual",

  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",

    "edit": "ask",
    "external_directory": "deny",

    "bash": {
      "*": "ask",

      "pwd": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "find *": "allow",

      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git fetch*": "allow",

      "git add*": "deny",
      "git commit*": "deny",
      "git push*": "deny",
      "git pull*": "deny",
      "git merge*": "deny",
      "git rebase*": "deny",
      "git checkout*": "deny",
      "git switch*": "deny",
      "git restore*": "deny",
      "git reset*": "deny",

      "rm *": "deny",
      "sudo *": "deny",
      "diskutil *": "deny",
      "dd *": "deny",
      "mkfs *": "deny"
    }
  }
}
